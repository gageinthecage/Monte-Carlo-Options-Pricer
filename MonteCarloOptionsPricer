import numpy as np

def B_S(S, K):
    result = max(S-K,0)
    return result

def  S_T(S,r,o,t):
    Z = np.random.randn()
    result = S* np.exp((r-o**2/2)*t+o * np.sqrt(t)*Z)
    return result

def MonteCarloPricer(K, S, r, o, t, n_simulations):
    payoffs = []
    for i in range (n_simulations):
        simulation_T = S_T(S, r, o ,t)
        payoff= B_S(simulation_T, K)
        payoffs.append(payoff)
    price = np.mean(payoffs) * np.exp(-r*t)
    return price
